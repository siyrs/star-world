[application]
config/name="星的世界"
config/version="1.1.0"
run/main_scene="res://scenes/game/game.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")

[autoload]
StarWorldUpdateService="*res://src/update/update_service.gd"
StarWorldUpdateMenuBridge="*res://src/update/update_menu_bridge.gd"

[display]
window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[physics]
common/enable_pause_aware_picking=true
3d/default_gravity=20.0

[layer_names]
3d_physics/layer_1="Voxel World"
3d_physics/layer_2="Player"
3d_physics/layer_3="Entities"
3d_physics/layer_4="Pickups"

[rendering]
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
